---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ToroLeadTicker from '@/components/ToroLeadTicker.astro';
import { Image } from 'astro:assets';
import kevinPhoto from '@/media/kevin-photo-1.jpg';
import toroLogo from '@/media/Official-Toro-Electric-Logo-2024-Optimized.png';
import twogetherLogo from '@/media/Twogether-Dental-Logo-Square-1200x1200px.png';
import resilienceLogo from '@/media/Resilience-Fitness-R-Logo.png';
import gqLogo from '@/media/GQ_red-blue.svg';
import yahooLogo from '@/media/330px-Yahoo!_(2019).svg.webp';
import blogtoLogo from '@/media/BlogTOLogo2015-new-red.webp';
import rev4Logo from '@/media/Rev4-Logo-2025.svg';

const accent = 'text-lime-300';

// Intake form shared styles (kept as consts to avoid repeating long class lists)
const h2Cls = 'text-2xl font-bold tracking-tight';
const leadCls = 'mt-3 text-neutral-400 leading-relaxed';
const labelCls = 'flex items-start gap-3 py-2 text-neutral-200 cursor-pointer hover:text-white transition-colors';
const choiceCls = 'mt-0.5 w-4 h-4 accent-lime-300 shrink-0';
const fieldCls = 'w-full mt-2 mb-3 px-4 py-3 rounded-md bg-neutral-800 border border-neutral-700 text-neutral-100 placeholder-neutral-500 focus:border-lime-300 focus:outline-none transition-colors';
const areaCls = fieldCls + ' min-h-[120px] resize-y';
const subLabelCls = 'mt-5 mb-1 font-semibold text-neutral-200';
const navCls = 'mt-8 flex gap-3';
const nextCls = 'next px-6 py-3 rounded-md bg-lime-300 text-neutral-950 font-semibold text-sm hover:bg-lime-200 transition-colors';
const backCls = 'back px-6 py-3 rounded-md border border-neutral-600 text-neutral-200 font-semibold text-sm hover:border-neutral-400 transition-colors';
---

<BaseLayout title="Home">
  <div class="min-h-screen bg-neutral-950 text-neutral-100 selection:bg-lime-300 selection:text-neutral-950">
    <!-- Header -->
    <header class="border-b border-neutral-800">
      <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center">
          <Image src={rev4Logo} alt="Rev4" class="h-9 w-auto" />
        </a>
        <nav class="flex items-center gap-6 text-sm">
          <a href="#proof" class="text-neutral-300 hover:text-white transition-colors">Success Stories</a>
          <a href="#how" class="text-neutral-300 hover:text-white transition-colors">How it works</a>          <a href="#about" class="text-neutral-300 hover:text-white transition-colors">About Kevin</a>
          <a href="#contact" class="px-4 py-1.5 rounded-md border border-neutral-600 hover:border-neutral-400 text-white transition-colors">Contact</a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <!-- 1 · Hero -->
      <section class="border-b border-neutral-800">
        <div class="max-w-4xl mx-auto px-4 py-10">
          <div class="grid md:grid-cols-2 gap-8 items-start">
            <div>
              <h1 class="text-3xl md:text-4xl font-bold leading-tight tracking-tight">
                This is what your inbox looks like when marketing <span class={accent}>actually works.</span>
              </h1>
              <div class="mt-6 flex items-center gap-3">
                <Image src={kevinPhoto} alt="Kevin" width={96} height={96} class="w-12 h-12 rounded-full object-cover" />
                <span class="text-sm text-neutral-300">Hi, I'm Kevin. Your Local Business Marketing Partner.</span>
              </div>
              <p class="mt-5 text-neutral-400 leading-relaxed">
                Want to stop being invisible online? Want more leads and increased sales? Get  ready-to-buy customers delivered to your inbox every week.
              </p>
              
              <div class="mt-6 flex items-center gap-5">
                <a href="#contact" class="px-5 py-2.5 rounded-md bg-lime-300 text-neutral-950 font-semibold text-sm hover:bg-lime-200 transition-colors">Ask me how</a>
                <a href="#proof" class="text-sm text-neutral-300 hover:text-white transition-colors">See Proof ↓</a>
              </div>
            </div>

            <!-- Inbox card (animated ticker) -->
            <ToroLeadTicker />
          </div>
        </div>
      </section>

      <!-- Proof wall -->
      <section id="proof" class="border-b border-neutral-800">
        <div class="max-w-4xl mx-auto px-4 py-10">
          <p class={`text-sm font-semibold tracking-widest uppercase mb-3 ${accent}`}>Don't take my word for it</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight uppercase">Client Success Stories</h2>
          <p class="mt-3 text-neutral-400">Three clients. Three different industries. Outstanding Results.</p>

          <div class="grid md:grid-cols-3 gap-4 mt-8">
            <!-- Toro Electric -->
            <div class="rounded-lg bg-neutral-900 border border-neutral-800 p-5 flex flex-col">
              <div class="flex items-start gap-3 mb-5">
                <span class="w-12 h-12 rounded-full bg-white flex items-center justify-center shrink-0 overflow-hidden">
                  <Image src={toroLogo} alt="Toro Electric logo" width={96} height={96} class="w-12 h-12 object-contain" />
                </span>
                <div>
                  <p class="font-bold leading-tight">Toro Electric</p>
                  <p class="text-sm text-neutral-400">Electrical · Toronto</p>
                </div>
              </div>
              <p class={`text-lg font-bold leading-snug mb-5 ${accent}`}>From occasional panel upgrade jobs to a weekly pipeline across the GTA.</p>
              <p class="mb-1"><span class="text-4xl font-bold">60</span> <span class="text-neutral-400">days</span></p>
              <p class="text-sm text-neutral-400 mb-3">Dozens of verified enquiries for:</p>
              <ul class="space-y-1.5 text-sm text-neutral-200 mb-6">
                <li><span class={accent}>✓</span> Panel upgrades</li>
                <li><span class={accent}>✓</span> EV chargers</li>
                <li><span class={accent}>✓</span> Hot tubs &amp; 200A service</li>
              </ul>
              <p class="mt-auto rounded-r-md bg-lime-300/10 border-l-2 border-lime-300 p-4 text-sm font-semibold text-neutral-100">Toro gets qualified leads each week. If the phone doesn't ring, I don't get paid.</p>
            </div>
            <!-- Twogether Dental -->
            <div class="rounded-lg bg-neutral-900 border border-neutral-800 p-5 flex flex-col">
              <div class="flex items-start gap-3 mb-5">
                <span class="w-12 h-12 rounded-full bg-white flex items-center justify-center shrink-0 overflow-hidden">
                  <Image src={twogetherLogo} alt="Twogether Dental logo" width={96} height={96} class="w-10 h-10 object-contain" />
                </span>
                <div>
                  <p class="font-bold leading-tight">Twogether Dental</p>
                  <p class="text-sm text-neutral-400">Dental implants</p>
                </div>
              </div>
              <p class={`text-lg font-bold leading-snug mb-5 ${accent}`}>From zero implant cases to three years fully booked new Implant cases.</p>
              <p class="mb-3"><span class="text-4xl font-bold">3</span> <span class="text-neutral-400">years running</span></p>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="text-xs px-2.5 py-1 rounded bg-neutral-800 text-neutral-200">'23 <span class={accent}>✓</span></span>
                <span class="text-xs px-2.5 py-1 rounded bg-neutral-800 text-neutral-200">'24 <span class={accent}>✓</span></span>
                <span class="text-xs px-2.5 py-1 rounded bg-neutral-800 text-neutral-200">'25 <span class={accent}>✓</span></span>
              </div>
              <p class="text-sm text-neutral-300 mb-6">Hundreds of implant and denture patients booked into treatment.</p>
              <p class="mt-auto rounded-r-md bg-lime-300/10 border-l-2 border-lime-300 p-4 text-sm font-semibold text-neutral-100">Twogether Dental smashes their previous revenue record thanks to new Implant cases.</p>
            </div>
            <!-- Resilience Fitness -->
            <div class="rounded-lg bg-neutral-900 border border-neutral-800 p-5 flex flex-col">
              <div class="flex items-start gap-3 mb-5">
                <span class="w-12 h-12 rounded-full bg-white flex items-center justify-center shrink-0 overflow-hidden">
                  <Image src={resilienceLogo} alt="Resilience Fitness logo" width={96} height={96} class="w-10 h-10 object-contain" />
                </span>
                <div>
                  <p class="font-bold leading-tight">Resilience Fitness</p>
                  <p class="text-sm text-neutral-400">HYROX &amp; hybrid training</p>
                </div>
              </div>
              <p class={`text-lg font-bold leading-snug mb-5 ${accent}`}>From just another gym to <em>the</em> #1 name in HYROX Toronto.</p>
              <p class="text-xs font-semibold tracking-widest uppercase text-neutral-400 mb-3">As seen in</p>
              <div class="flex flex-nowrap gap-2 mb-5">
                <span class="px-3 py-1.5 rounded-md bg-white flex items-center justify-center min-w-0">
                  <Image src={gqLogo} alt="GQ" class="h-4 w-auto max-w-full object-contain" />
                </span>
                <span class="px-3 py-1.5 rounded-md bg-white flex items-center justify-center min-w-0">
                  <Image src={yahooLogo} alt="Yahoo!" class="h-4 w-auto max-w-full object-contain" />
                </span>
                <span class="px-3 py-1.5 rounded-md bg-white flex items-center justify-center min-w-0">
                  <Image src={blogtoLogo} alt="blogTO" class="h-4 w-auto max-w-full object-contain" />
                </span>
              </div>
              <ul class="space-y-1.5 text-sm text-neutral-200 mb-6">
                <li><span class={accent}>✓</span> Ranked #1 on Google for HYROX Toronto</li>
                <li><span class={accent}>✓</span> Voted #1 HYROX gym in Toronto</li>
              </ul>
              <p class="mt-auto rounded-r-md bg-lime-300/10 border-l-2 border-lime-300 p-4 text-sm font-semibold text-neutral-100">Resilience dominates the HYROX fitness niche and expands to 3rd location.</p>
            </div>
          </div>

          <!-- Testimonial bar -->
          <div class="mt-6 rounded-lg bg-neutral-900 border border-neutral-800 border-l-2 border-l-lime-300 p-5">
            <p class="text-neutral-100"><span class={`text-2xl leading-none mr-1 ${accent}`}>“</span>Kevin's advice just made sense. He gave us the clarity we needed to stop guessing and start growing.</p>
            <p class="mt-3 text-sm"><span class="font-semibold">Andrew Gillis</span> <span class="text-neutral-400">· Co-founder, Resilience Fitness</span></p>
          </div>
        </div>
      </section>

      <!-- 4 · Risk ladder -->
      <section id="how" class="border-b border-neutral-800">
        <div class="max-w-4xl mx-auto px-4 py-10">
          <p class={`text-sm font-semibold tracking-widest uppercase mb-3 ${accent}`}>If those stories resonated</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight uppercase">Here's How We Start</h2>
          <p class="mt-3 text-neutral-400">Four steps, smallest first. Each step is low risk, keep going if it's working, walk away if it's not. No contracts, no bundles, and the price I quote is the price you pay.</p>

          <div class="grid md:grid-cols-4 gap-4 mt-8">
            <div class="rounded-lg bg-neutral-900 border border-neutral-800 p-5">
              <p class="font-semibold mb-2">Talk · $0</p>
              <p class="text-sm text-neutral-400">Free call. Worst case, free advice.</p>
            </div>
            <div class="rounded-lg bg-neutral-900 border border-neutral-800 p-5">
              <p class="font-semibold mb-2">Roadmap · $999</p>
              <p class="text-sm text-neutral-400">Keep it even if you never hire me.</p>
            </div>
            <div class="rounded-lg bg-neutral-900 border border-neutral-800 p-5">
              <p class="font-semibold mb-2">Build · $75/hr</p>
              <p class="text-sm text-neutral-400">Pay for work, not promises.</p>
            </div>
            <div class="rounded-lg bg-neutral-900 border border-lime-300 p-5">
              <p class={`font-semibold mb-2 ${accent}`}>Grow · $1.5k/mo</p>
              <p class="text-sm text-neutral-400">Cancel anytime. I earn it monthly.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- 5 · Roster / disqualify -->
      <section id="about" class="border-b border-neutral-800 scroll-mt-20">
        <div class="max-w-4xl mx-auto px-4 py-10">
          <p class={`text-sm font-semibold tracking-widest uppercase mb-3 ${accent}`}>Still deciding?</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight uppercase">about Kevin</h2>
          <p class="mt-3 text-neutral-400">I'm a Toronto based freelance marketer and web developer that works with a small roster of local businesses that want to get more leads.</p>

          <div class="grid md:grid-cols-2 gap-8 mt-8">
          
          <div>
          <p class="font-semibold mb-2">Small By Design</p>
           
            <p class="text-neutral-300 leading-relaxed">
          I cap my client list on purpose — fewer clients means you get more of me. You text me, I answer. No account managers, no ticket queue.
            </p>
          </div>
          
          <div>
            <p class="font-semibold mb-2">Marketer Who Codes</p>
            <p class="text-neutral-300 leading-relaxed">
              Strategy, site, ads, tracking — one source, full solution. No handoff delays, no waiting on a developer, nothing lost in translation.
            </p>
          </div>
           
          <div>
          <p class="font-semibold mb-2">No Juniors</p>
           
            <p class="text-neutral-300 leading-relaxed">
           I do all the work myself, so I stay close to every step — and you'll never pay a junior to learn on your dime.
            </p>
          </div>

         <div>
          <p class="font-semibold mb-2">We Might Not Be A Good Fit If...</p>
           
            <p class="text-neutral-300 leading-relaxed">
           You want overnight miracles, need an on-call IT department, or can't spare the occasional call.
            </p>
          </div>
          
          </div>


        </div>
      </section>

      <!-- 6 · Intake form -->
      <section id="contact" class="scroll-mt-20">
        <div class="max-w-4xl mx-auto px-4 py-10">
          <div class="rounded-xl bg-neutral-900 border border-neutral-800 p-6 sm:p-8 grid md:grid-cols-[1.1fr_1fr] gap-8 md:gap-10 items-center">
          <div class="min-w-0">
          <form id="rev4-intake-form" action="https://usebasin.com/f/f4aedf04c70c" method="POST">
            <input type="hidden" name="submission_id" id="submission_id" />
            <input type="hidden" name="form_status" id="form_status" value="draft" />
            <input type="hidden" name="current_step" id="current_step" value="1" />

            <!-- Step 1 -->
            <div class="form-step" data-step="1">
              <h2 class={h2Cls}>Want your inbox to look like <span class={accent}>this?</span></h2>
              <p class={leadCls}>Five minutes. Then a free call. Then you decide.</p>
              <div class="mt-8 flex items-center gap-4">
                <button type="button" class={nextCls}>Get Started</button>
                <!-- Desktop: arrow points right to the inbox card -->
                <svg width="72" height="34" viewBox="0 0 72 34" fill="none" aria-hidden="true" class="hidden md:block shrink-0">
                  <path d="M4 26 C 26 30, 48 22, 64 8" stroke="#a3e635" stroke-width="2" stroke-linecap="round" fill="none" stroke-dasharray="3 5"/>
                  <path d="M56 7 L 65 7 L 62 16" stroke="#a3e635" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                </svg>
                <!-- Mobile: arrow points down to the stacked inbox card -->
                <svg width="34" height="56" viewBox="0 0 34 56" fill="none" aria-hidden="true" class="md:hidden shrink-0">
                  <path d="M10 4 C 26 12, 28 28, 20 44" stroke="#a3e635" stroke-width="2" stroke-linecap="round" fill="none" stroke-dasharray="3 5"/>
                  <path d="M11 41 L 19 50 L 27 42" stroke="#a3e635" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                </svg>
              </div>
            </div>

            <!-- Step 2 -->
            <div class="form-step hidden" data-step="2">
              <h2 class={h2Cls}>Desired Outcome</h2>
              <p class={leadCls}>If we worked together, what outcome would make you say, “Hiring Rev4 was one of the best decisions we made”?</p>
              <div class="mt-4">
                <label class={labelCls}><input type="checkbox" name="desired_outcome[]" value="Increase revenue" class={choiceCls} /> Increase revenue</label>
                <label class={labelCls}><input type="checkbox" name="desired_outcome[]" value="Generate better quality leads" class={choiceCls} /> Generate better quality leads</label>
                <label class={labelCls}><input type="checkbox" name="desired_outcome[]" value="Become known for a specific service or niche" class={choiceCls} /> Become known for a specific service or niche</label>
                <label class={labelCls}><input type="checkbox" name="desired_outcome[]" value="Improve marketing ROI" class={choiceCls} /> Improve marketing ROI</label>
                <label class={labelCls}><input type="checkbox" name="desired_outcome[]" value="Modernize our website" class={choiceCls} /> Modernize our website</label>
                <label class={labelCls}><input type="checkbox" name="desired_outcome[]" value="Understand what is actually working" class={choiceCls} /> Understand what’s actually working</label>
                <label class={labelCls}><input type="checkbox" name="desired_outcome[]" value="Reduce spam and junk leads" class={choiceCls} /> Reduce spam and junk leads</label>
                <label class={labelCls}><input type="checkbox" name="desired_outcome[]" value="Improve AI visibility" class={choiceCls} /> Improve AI visibility</label>
                <label class={labelCls}><input type="checkbox" name="desired_outcome[]" value="Automate repetitive work" class={choiceCls} /> Automate repetitive work</label>
                <label class={labelCls}><input type="checkbox" name="desired_outcome[]" value="Other" class={choiceCls} /> Other</label>
              </div>
              <div class={navCls}>
                <button type="button" class={backCls}>Back</button>
                <button type="button" class={nextCls}>Next</button>
              </div>
            </div>

            <!-- Step 3 -->
            <div class="form-step hidden" data-step="3">
              <h2 class={h2Cls}>Biggest Challenge</h2>
              <p class={leadCls}>In your own words, what’s the biggest challenge preventing you from reaching that outcome?</p>
              <textarea name="biggest_challenge" class={areaCls} placeholder="Tell me what's going on. You don't need to use marketing language — just explain the situation as you see it."></textarea>
              <div class={navCls}>
                <button type="button" class={backCls}>Back</button>
                <button type="button" class={nextCls}>Next</button>
              </div>
            </div>

            <!-- Step 4 -->
            <div class="form-step hidden" data-step="4">
              <h2 class={h2Cls}>Current Situation</h2>
              <p class={leadCls}>Which statement sounds most like your business today?</p>
              <div class="mt-4">
                <label class={labelCls}><input type="radio" name="current_situation" value="Growing but plateaued" class={choiceCls} /> We’re growing, but we’ve hit a plateau.</label>
                <label class={labelCls}><input type="radio" name="current_situation" value="Could grow faster" class={choiceCls} /> We know we could grow faster.</label>
                <label class={labelCls}><input type="radio" name="current_situation" value="Marketing disconnected" class={choiceCls} /> Our marketing feels disconnected.</label>
                <label class={labelCls}><input type="radio" name="current_situation" value="Do not know what is working" class={choiceCls} /> We don’t know what’s actually working.</label>
                <label class={labelCls}><input type="radio" name="current_situation" value="Too many vendors" class={choiceCls} /> We have too many vendors.</label>
                <label class={labelCls}><input type="radio" name="current_situation" value="Wrong leads" class={choiceCls} /> We’re generating leads but not enough of the right ones.</label>
                <label class={labelCls}><input type="radio" name="current_situation" value="Need clearer direction" class={choiceCls} /> We need a clearer direction.</label>
                <label class={labelCls}><input type="radio" name="current_situation" value="Something else" class={choiceCls} /> Something else.</label>
              </div>
              <div class={navCls}>
                <button type="button" class={backCls}>Back</button>
                <button type="button" class={nextCls}>Next</button>
              </div>
            </div>

            <!-- Step 5 -->
            <div class="form-step hidden" data-step="5">
              <h2 class={h2Cls}>What You Want to Be Known For</h2>
              <p class={leadCls}>What would you like your business to become known for?</p>
              <textarea name="known_for" class={areaCls} placeholder="Example: “Panel upgrades”, “high-end renovations”, “commercial HVAC”, etc."></textarea>
              <div class={navCls}>
                <button type="button" class={backCls}>Back</button>
                <button type="button" class={nextCls}>Next</button>
              </div>
            </div>

            <!-- Step 6 -->
            <div class="form-step hidden" data-step="6">
              <h2 class={h2Cls}>Timeline</h2>
              <p class={leadCls}>How soon are you hoping to improve things?</p>
              <div class="mt-4">
                <label class={labelCls}><input type="radio" name="timeline" value="Immediately" class={choiceCls} /> Immediately</label>
                <label class={labelCls}><input type="radio" name="timeline" value="Within 30 days" class={choiceCls} /> Within 30 days</label>
                <label class={labelCls}><input type="radio" name="timeline" value="Within 3 months" class={choiceCls} /> Within 3 months</label>
                <label class={labelCls}><input type="radio" name="timeline" value="Within 6 months" class={choiceCls} /> Within 6 months</label>
                <label class={labelCls}><input type="radio" name="timeline" value="Just exploring" class={choiceCls} /> Just exploring</label>
              </div>
              <div class={navCls}>
                <button type="button" class={backCls}>Back</button>
                <button type="button" class={nextCls}>Next</button>
              </div>
            </div>

            <!-- Step 7 -->
            <div class="form-step hidden" data-step="7">
              <h2 class={h2Cls}>Budget Range</h2>
              <p class={leadCls}>If I identify a worthwhile opportunity, what investment would you be comfortable making?</p>
              <div class="mt-4">
                <label class={labelCls}><input type="radio" name="budget_range" value="Under $2500" class={choiceCls} /> Under $2,500</label>
                <label class={labelCls}><input type="radio" name="budget_range" value="$2500-$5000" class={choiceCls} /> $2,500–$5,000</label>
                <label class={labelCls}><input type="radio" name="budget_range" value="$5000-$10000" class={choiceCls} /> $5,000–$10,000</label>
              </div>
              <div class={navCls}>
                <button type="button" class={backCls}>Back</button>
                <button type="button" class={nextCls}>Next</button>
              </div>
            </div>

            <!-- Step 8 -->
            <div class="form-step hidden" data-step="8">
              <h2 class={h2Cls}>Working Together</h2>
              <p class={leadCls}>The businesses that get the best results usually participate along the way. That may mean sharing photos or videos, asking customers for reviews, providing updates, giving feedback, or giving access to systems I need to review.</p>
              <p class="mt-3 text-neutral-200 font-semibold">Which statement best describes you?</p>
              <div class="mt-4">
                <label class={labelCls}><input type="radio" name="working_together" value="Happy to be involved" class={choiceCls} /> I’m happy to be involved if it helps us get better results.</label>
                <label class={labelCls}><input type="radio" name="working_together" value="Can contribute occasionally" class={choiceCls} /> I can contribute occasionally, but my time is limited.</label>
                <label class={labelCls}><input type="radio" name="working_together" value="Minimal input" class={choiceCls} /> I’m looking for someone to handle everything with minimal input from me.</label>
              </div>
              <div class={navCls}>
                <button type="button" class={backCls}>Back</button>
                <button type="button" class={nextCls}>Next</button>
              </div>
            </div>

            <!-- Step 9 -->
            <div class="form-step hidden" data-step="9">
              <h2 class={h2Cls}>Contact Details</h2>
              <p class={leadCls}>Please share your contact details so I can review your answers and arrange a Zoom conversation.</p>

              <input name="company_name" class={fieldCls} placeholder="Company Name" required />
              <input name="your_name" class={fieldCls} placeholder="Your Name" required />
              <input name="email" type="email" class={fieldCls} placeholder="Email Address" required />
              <input name="phone" class={fieldCls} placeholder="Phone Number" />
              <input name="website" class={fieldCls} placeholder="Website" />

              <p class={subLabelCls}>Best way to reach you</p>
              <div>
                <label class={labelCls}><input type="radio" name="best_contact_method" value="Phone" class={choiceCls} /> Phone</label>
                <label class={labelCls}><input type="radio" name="best_contact_method" value="Email" class={choiceCls} /> Email</label>
                <label class={labelCls}><input type="radio" name="best_contact_method" value="Text" class={choiceCls} /> Text</label>
              </div>

              <p class={subLabelCls}>Best time to contact you</p>
              <div>
                <label class={labelCls}><input type="radio" name="best_contact_time" value="Morning" class={choiceCls} /> Morning</label>
                <label class={labelCls}><input type="radio" name="best_contact_time" value="Afternoon" class={choiceCls} /> Afternoon</label>
                <label class={labelCls}><input type="radio" name="best_contact_time" value="Evening" class={choiceCls} /> Evening</label>
              </div>

              <div class={navCls}>
                <button type="button" class={backCls}>Back</button>
                <button type="submit" class={nextCls.replace('next ', '')}>Submit</button>
              </div>
            </div>
          </form>

          <div id="form-success" hidden class="rounded-lg border border-lime-300 p-6 text-center">
            <h2 class={h2Cls}>Thanks — I’ve got it.</h2>
            <p class={leadCls}>I’ll review your answers before our conversation. The next step is to choose a time that works for you.</p>
          </div>
          </div>

          <!-- Animated inbox preview card -->
          <div class="min-w-0 bg-white rounded-lg p-4">
            <div class="flex items-center justify-between pb-2 border-b border-neutral-200">
              <span class="text-sm font-semibold text-neutral-900">Twogether Dental New leads</span>
              <span class="flex items-center gap-1.5 rounded-full bg-lime-100 px-2.5 py-0.5 text-xs font-medium text-lime-800">
                <span class="inline-block w-1.5 h-1.5 rounded-full bg-lime-600 animate-pulse motion-reduce:animate-none"></span>
                New
              </span>
            </div>
            <div id="lead-feed" class="h-[220px] overflow-hidden" aria-hidden="true"></div>
            <p class="mt-2 text-center text-xs text-neutral-400">A typical week, replayed &middot; details redacted</p>
          </div>
          </div>
        </div>
      </section>

      <script is:inline>
        (function () {
          var feed = document.getElementById('lead-feed');
          if (!feed) return;
          var pool = [
            { n: 'Implant consult', s: '"Missing two molars, ready to book…"' },
            { n: 'Denture consult', s: '"Looking at options for my father…"' },
            { n: 'Full mouth implant consult', s: '"Want to discuss full-mouth options…"' },
            { n: 'Invisalign consult', s: '"Hoping for straighter teeth by summer…"' },
            { n: 'Implant denture consult', s: '"Tired of loose dentures, what next…"' }
          ];
          var times = ['just now', '38 min ago', '2 hrs ago', 'yesterday'];
          var idx = 0;
          var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          function rowEl(item, t) {
            var d = document.createElement('div');
            d.className = 'lead-row py-2 border-b border-neutral-100 transition-all duration-500 motion-reduce:transition-none';
            d.innerHTML = '<div class="flex justify-between items-baseline gap-2"><span class="lead-name text-sm font-medium text-neutral-900"></span><span class="lead-time text-xs text-neutral-400 whitespace-nowrap"></span></div><div class="lead-snip text-xs text-neutral-500 mt-0.5 truncate"></div>';
            d.querySelector('.lead-name').textContent = item.n;
            d.querySelector('.lead-time').textContent = t;
            d.querySelector('.lead-snip').textContent = item.s;
            return d;
          }

          function retime() {
            var rows = feed.children;
            for (var i = 0; i < rows.length; i++) {
              var el = rows[i].querySelector('.lead-time');
              if (el) el.textContent = times[Math.min(i, times.length - 1)];
            }
          }

          for (var i = 0; i < 4; i++) {
            feed.appendChild(rowEl(pool[idx % pool.length], times[i]));
            idx++;
          }

          if (reduced) return;

          setInterval(function () {
            var row = rowEl(pool[idx % pool.length], 'just now');
            idx++;
            row.classList.add('opacity-0', '-translate-y-2.5');
            feed.insertBefore(row, feed.firstChild);
            requestAnimationFrame(function () {
              requestAnimationFrame(function () {
                row.classList.remove('opacity-0', '-translate-y-2.5');
              });
            });
            while (feed.children.length > 4) feed.removeChild(feed.lastChild);
            retime();
          }, 3200);
        })();
      </script>

      <script is:inline>
        (function () {
          const form = document.getElementById("rev4-intake-form");
          if (!form) return;
          const steps = Array.from(form.querySelectorAll(".form-step"));
          const success = document.getElementById("form-success");
          const endpoint = form.getAttribute("action");

          let currentStep = 0;

          const submissionIdField = document.getElementById("submission_id");
          const formStatusField = document.getElementById("form_status");
          const currentStepField = document.getElementById("current_step");

          submissionIdField.value =
            "rev4-" + Date.now() + "-" + Math.random().toString(36).slice(2);

          function showStep(index) {
            steps.forEach((step, i) => {
              step.classList.toggle("hidden", i !== index);
            });
            currentStep = index;
            currentStepField.value = String(index + 1);
          }

          function getCurrentStepFields() {
            return Array.from(steps[currentStep].querySelectorAll("input, textarea, select"));
          }

          function validateStep() {
            const fields = getCurrentStepFields();
            for (const field of fields) {
              if (field.hasAttribute("required") && !field.value.trim()) {
                field.focus();
                return false;
              }
            }
            return true;
          }

          async function saveDraft() {
            formStatusField.value = "draft";
            const formData = new FormData(form);
            formData.set("form_status", "draft");
            formData.set("current_step", String(currentStep + 1));
            try {
              await fetch(endpoint, { method: "POST", body: formData, mode: "no-cors" });
            } catch (error) {
              console.warn("Draft save failed:", error);
            }
          }

          form.addEventListener("click", async function (event) {
            if (event.target.classList.contains("next")) {
              if (!validateStep()) return;
              await saveDraft();
              if (currentStep < steps.length - 1) {
                showStep(currentStep + 1);
              }
            }
            if (event.target.classList.contains("back")) {
              if (currentStep > 0) {
                showStep(currentStep - 1);
              }
            }
          });

          form.addEventListener("submit", async function (event) {
            event.preventDefault();
            if (!validateStep()) return;
            formStatusField.value = "completed";
            const formData = new FormData(form);
            formData.set("form_status", "completed");
            formData.set("current_step", String(currentStep + 1));
            try {
              await fetch(endpoint, { method: "POST", body: formData, mode: "no-cors" });
              form.hidden = true;
              success.hidden = false;
            } catch (error) {
              alert("Something went wrong. Please try again.");
              console.error(error);
            }
          });

          showStep(0);
        })();
      </script>
    </main>

